{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "libros": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ISBN": {
            "type": "string",
            "pattern": "^(\\d{3}-){4}\\d{1}$"
          },
          "tipo": {
            "type": "string",
            "enum": ["novela", "ensayo", "biografia"]
          },
          "categoria": {
            "type": "string",
            "enum": ["prestamo", "consulta"]
          },
          "titulo": {
            "type": "string"
          },
          "autores": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "nombre": {
                  "type": "string"
                },
                "apellido": {
                  "type": "string"
                },
                "nacionalidad": {
                  "type": "string"
                }
              },
              "required": ["nombre", "apellido"],
              "additionalProperties": false
            },
            "minItems": 1
          },
          "editor": {
            "type": "object",
            "properties": {
              "nombre": {
                "type": "string"
              },
              "apellidos": {
                "type": "string"
              },
              "nacionalidad": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "numeroPaginas": {
            "type": "integer"
          },
          "anioPublicacion": {
            "type": "integer",
            "pattern": "^[0-9]{4}$"
          }
        },
        "required": ["titulo", "categoria", "autores"],
        "additionalProperties": false
      },
      "minItems": 1,
      "maxItems": 500
    }
  },
  "required": ["libros"],
  "additionalProperties": false,
  "patternProperties": {
    "^\\$": {}
  }
}
