{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "biblioteca": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "properties": {
          "ISBN": {
            "type": "string",
            "pattern": "^(\\d{3}-){4}\\d{1}$"
          },
          "tipo": {
            "type": "string",
            "enum": ["novela", "ensayo", "biografia"]
          }
        },
        "required": ["ISBN", "tipo"],
        "additionalProperties": false
      }
    }
  },
  "required": ["biblioteca"]
}
